{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/capability.schema.json",
  "title": "Capability",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "description",
    "inputs",
    "outputs",
    "patterns",
    "steps",
    "use_cases",
    "prompt_templates",
    "metadata"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/io_item"
      },
      "default": []
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/io_item"
      },
      "default": []
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "use_cases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "prompt_templates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prompt_template"
      },
      "default": []
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "automation",
        "analysis",
        "scraping",
        "content",
        "integration",
        "data",
        "workflow",
        "other"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "source_signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "language": {
          "type": "string"
        },
        "stars": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo_name": {
          "type": "string"
        },
        "repo_url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "repo_name",
        "repo_url"
      ]
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "type": {
      "type": "string"
    }
  },
  "$defs": {
    "io_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "prompt_template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "template"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "stars",
        "repo_url"
      ],
      "properties": {
        "language": {
          "type": "string"
        },
        "stars": {
          "type": "integer",
          "minimum": 0
        },
        "repo_url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}